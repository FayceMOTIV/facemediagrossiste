rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isManager() {
      return isAuthenticated() && (getUserRole() == 'manager' || getUserRole() == 'admin');
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() in ['admin', 'manager', 'commercial'];
    }

    function isLivreur() {
      return isAuthenticated() && getUserRole() == 'livreur';
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isManager());
      allow create: if isAdmin();
      allow update: if isOwner(userId) || isManager();
      allow delete: if isAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Products
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isStaff() || isLivreur() ||
        (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isStaff() ||
        (isAuthenticated() && getUserRole() == 'client');
      allow update: if isStaff() || isLivreur();
      allow delete: if isManager();
    }

    // Deliveries
    match /deliveries/{deliveryId} {
      allow read: if isStaff() || isLivreur() ||
        (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff() || isLivreur();
      allow delete: if isManager();
    }

    // Quotes
    match /quotes/{quoteId} {
      allow read: if isStaff() ||
        (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isStaff();
    }

    // Alerts
    match /alerts/{alertId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isManager();
    }

    // Prospects
    match /prospects/{prospectId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Stocks
    match /stocks/{stockId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // Activity logs (audit trail)
    match /activity_logs/{logId} {
      allow read: if isManager();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Churn analyses
    match /churn_analyses/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Route optimizations
    match /route_optimizations/{id} {
      allow read: if isStaff() || isLivreur();
      allow write: if isStaff() || isLivreur();
    }

    // Stock predictions
    match /stock_predictions/{id} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Demo requests (public write for vitrine)
    match /demo_requests/{id} {
      allow read: if isManager();
      allow create: if true;
      allow update, delete: if isManager();
    }

    // Chat conversations
    match /conversations/{convId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isManager());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isManager());
      allow delete: if isAdmin();
    }
  }
}
